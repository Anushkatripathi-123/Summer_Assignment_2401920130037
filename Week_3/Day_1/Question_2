//Reverse Linked List

class Solution {
    public ListNode reverseList(ListNode head) {
        if(head==null||head.next==null)
        return head;
        ListNode temp=null;
        ListNode current=head;
        while(current!=null)
        {
           ListNode prev=current.next;
           current.next=temp;
           temp=current;
           current=prev;
        }
        return temp;
        
    }
}