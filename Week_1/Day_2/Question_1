//Maximum Sub Array

class Solution {
    public int maxSubArray(int[] nums) {
        long max=Long.MIN_VALUE;
        long sum=0;
        int n=nums.length;
        for(int i=0;i<n;i++)
        {
            sum=sum+nums[i];
            max=Math.max(sum,max);
            if(sum<0)
            {
                sum=0;
            }
        
        }
        return (int)max;
    }
}